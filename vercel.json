{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/services/(?<slug>[^/]+)",
      "dest": "/api/services/[slug].js"
    },
    {
      "src": "/api/services",
      "dest": "/api/services.js"
    },
    {
      "src": "/api/ai/chat",
      "dest": "/api/ai/chat.js"
    },
    {
      "src": "/api/ai/check-document",
      "dest": "/api/ai/check-document.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
